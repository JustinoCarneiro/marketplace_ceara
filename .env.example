# Marketplace de Serviços Residenciais (Ceará) — variáveis de ambiente
# Copie para .env e preencha antes de iniciar o projeto.
# NUNCA commite o arquivo .env — ele está no .gitignore.

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=onda_user
POSTGRES_PASSWORD=troque-em-producao
POSTGRES_DB=onda_db
DATABASE_URL=jdbc:postgresql://localhost:5432/onda_db

# ── JWT (min 32 chars em produção) ───────────────────────────────────────────
JWT_SECRET=troque-em-producao-min-32-caracteres!!

# ── CPF encryption (AES-256 → exatamente 32 chars) ───────────────────────────
CPF_ENCRYPTION_KEY=01234567890123456789012345678901

# ── Webhook do gateway de pagamento ──────────────────────────────────────────
MARKETPLACE_WEBHOOK_SECRET=troque-em-producao-segredo-webhook

# ── Admin padrão do Spring Security (não usar em produção) ───────────────────
ADMIN_USER=admin
ADMIN_PASS=troque-em-producao

# ── E-mail (alertas SOS / Disputa / Verificação) ─────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app

# ── Destinatário dos alertas operacionais ────────────────────────────────────
ADMIN_ALERT_EMAIL=admin@marketplace-ceara.com.br

# ── pgAdmin (apenas dev local) ───────────────────────────────────────────────
PGADMIN_EMAIL=admin@onda.com
PGADMIN_PASSWORD=admin
PROJECT_NAME=onda

# ── Marketplace (opcionais — sobrescrevem defaults do application.yml) ────────
# MARKETPLACE_COMISSAO=0.15
# MARKETPLACE_OUTBOX_DELAY_MS=5000
